# Copy to .env locally, or set these as SECRET env vars in DigitalOcean App Platform.
# NEVER commit real values.
VENICE_KEY=your-venice-api-key
ADMIN_TOKEN=make-a-long-random-string
ALLOWED_ORIGIN=https://catboy-ecru.vercel.app
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret
SPACES_REGION=nyc3
SPACES_BUCKET=catboy-assets
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_CDN=https://catboy-assets.nyc3.cdn.digitaloceanspaces.com
