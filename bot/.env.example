# CATBOY buy bot — copy to ".env" and fill in. Never commit the real .env.

# From @BotFather (create a bot, /newbot). Required.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# The chat/channel/group to post in. Add the bot to the group as admin.
# For a group, this is a negative number (e.g. -1001234567890). Required.
# Tip: message @RawDataBot or @userinfobot in the group to get the chat id.
TELEGRAM_CHAT_ID=-1001234567890

# Your pump.fun token mint address. Set this AT LAUNCH, then restart the bot
# (or send it SIGHUP to reload). Leave blank until you have it.
TOKEN_MINT=

# Ticker shown in alerts.
TOKEN_TICKER=CATBOY

# Don't alert on buys smaller than this (SOL).
MIN_BUY_SOL=0.05

# Emoji used for the buy bar, and how many SOL per emoji.
BUY_EMOJI=🐾
EMOJI_STEP_SOL=0.1
EMOJI_MAX=96

# Buy GIF: a local file path (default media/buy.gif) OR an https URL.
BUY_MEDIA=media/buy.gif

# Your site (shown as a link in alerts).
SITE_URL=https://www.catboyonsol.fun

# PumpPortal data websocket (default is fine).
PUMPPORTAL_WS=wss://pumpportal.fun/api/data

# --- DexScreener (real USD price/mcap + launch alerts) ---
# The bot polls DexScreener for accurate price & market cap, announces when the
# chart goes live and when the token graduates to a DEX, and posts market-cap
# milestone alerts. All defaults are fine.
DEX_POLL_MS=30000
# 1 = announce "graduated to Raydium/PumpSwap" once it migrates. 0 = off.
ANNOUNCE_MIGRATION=1
# Market-cap milestones (USD, comma-separated). Empty to disable.
MCAP_MILESTONES=10000,25000,50000,100000,250000,500000,1000000
