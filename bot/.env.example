# CATBOY buy bot — copy to ".env" and fill in. Never commit the real .env.

# From @BotFather (create a bot, /newbot). Required.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# The chat/channel/group to post in. Add the bot to the group as admin.
# For a group, this is a negative number (e.g. -1001234567890). Required.
# Tip: message @RawDataBot or @userinfobot in the group to get the chat id.
TELEGRAM_CHAT_ID=-1001234567890

# Your pump.fun token mint address. Leave blank before launch. You can either
# set this at launch (restart / SIGHUP), OR leave it blank and let the bot
# auto-detect the launch via CREATOR_WALLET / MATCH_SYMBOL below.
TOKEN_MINT=

# --- Launch (so you never miss the open) ---
# EASIEST, most reliable: at launch, DM the bot  /setmint <CA>  and it locks on
# instantly + alerts the group. Works even if you don't know the launch wallet.
# For that (and the priority ping) set NOTIFY_CHAT_ID to your Telegram user id.
# DM the bot, press Start, send /id — it replies with your id. Put it here:
NOTIFY_CHAT_ID=

# OPTIONAL: if you DO know the exact wallet that will create the token, set it
# and the bot auto-locks the instant that wallet launches (no /setmint needed).
CREATOR_WALLET=
# The bot also watches for any token with this ticker and DMs you the candidate
# CA as a heads-up (it never auto-locks on a symbol — copycats spoof it).
MATCH_SYMBOL=CATBOY
# Optionally allow another Telegram id to run /setmint (defaults to NOTIFY_CHAT_ID).
ADMIN_CHAT_ID=

# Ticker shown in alerts.
TOKEN_TICKER=CATBOY

# Don't alert on buys smaller than this (SOL).
MIN_BUY_SOL=0.05

# Emoji used for the buy bar, and how many SOL per emoji.
BUY_EMOJI=🐾
EMOJI_STEP_SOL=0.1
EMOJI_MAX=96

# Buy GIF: a local file path (default media/buy.gif) OR an https URL.
BUY_MEDIA=media/buy.gif

# Your site (shown as a link in alerts).
SITE_URL=https://www.catboyonsol.fun

# PumpPortal data websocket (default is fine).
PUMPPORTAL_WS=wss://pumpportal.fun/api/data

# --- AI chat personality (optional, cheap/free) ---
# The bot replies as Catboy when tagged/replied-to, and occasionally chimes in
# on random posts. Uses any OpenAI-compatible endpoint. Recommended: Groq (free,
# fast) — get a key at https://console.groq.com/keys . Leave blank to disable.
# IMPORTANT: to let the bot see (and randomly reply to) normal group messages,
# turn OFF privacy mode: @BotFather -> /mybots -> your bot -> Bot Settings ->
# Group Privacy -> Turn off. (Mentions/replies work even with privacy on.)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MODEL=llama-3.3-70b-versatile
REPLY_CHANCE=0.06          # odds (0-1) of chiming in on a random post
LLM_MAX_PER_MIN=6          # max AI replies per minute (spam/cost guard)

# --- $CATBOY AI (in-chat image/video credits) ---
# Powers /img, /vid, /credits, /balance. This block is what makes /credits work.
# REQUIRED for top-ups: a shared secret used to sign the credit link. It MUST be
# byte-for-byte IDENTICAL to the AI_SECRET you set in Vercel (api/credits.js
# verifies the link with it). Any random string; generate one and use the SAME
# value in both places. Without it the bot replies "Top-ups aren't configured yet."
AI_SECRET=
# The image/video provider (kept out of the code so the repo reveals no source).
# Leave AI_PROVIDER_KEY blank to keep /img disabled; /credits still works with just
# AI_SECRET above. AI_TREASURY (the SOL wallet that receives top-ups) is set on
# VERCEL, not here — this bot never touches the money.
AI_PROVIDER_KEY=
AI_PROVIDER_BASE=https://api.your-provider.example/v1
AI_IMAGE_MODEL=
AI_VIDEO_MODEL=
AI_SITE=https://www.catboyonsol.fun
# Prices (USD cents) per generation, cooldown, and video toggle. Defaults shown.
AI_IMG_PRICE_CENTS=30
AI_VID_PRICE_CENTS=150
AI_COOLDOWN_SEC=20
AI_ENABLE_VIDEO=0
AI_LOW_BALANCE_USD=10

# --- Burn alerts ---
# Poll the token supply and post 🔥 when it drops. Uses a public Solana RPC.
ANNOUNCE_BURNS=1
RPC_URL=https://api.mainnet-beta.solana.com
BURN_POLL_MS=60000

# --- DexScreener (real USD price/mcap + launch alerts) ---
# The bot polls DexScreener for accurate price & market cap, announces when the
# chart goes live and when the token graduates to a DEX, and posts market-cap
# milestone alerts. All defaults are fine.
DEX_POLL_MS=30000
# 1 = announce "graduated to Raydium/PumpSwap" once it migrates. 0 = off.
ANNOUNCE_MIGRATION=1
# Market-cap milestones (USD, comma-separated). Empty to disable.
MCAP_MILESTONES=10000,25000,50000,100000,250000,500000,1000000
