# --- Robinhood Chain bubble maps ---
# FREE first. Alchemy is fallback / enhanced-only.

RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com   # PRIMARY (free, $0)
# RH_RPC_URL_2=                                        # optional extra free endpoint

# FALLBACK ONLY — used when the free RPC fails/rate-limits, or for getAssetTransfers
# (native-funding clusters) and trace_. Leave empty to stay 100% free.
# ALCHEMY_RPC_URL=https://rh-mainnet.g.alchemy.com/v2/YOUR_KEY

# Separate Neon DB from the catboy bot (do NOT reuse the bot's DATABASE_URL).
# BUBBLE_DATABASE_URL=postgres://...
