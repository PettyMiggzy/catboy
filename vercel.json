{
  "git": {
    "deploymentEnabled": {
      "claude/catboy-website-nspovy": false
    }
  },
  "headers": [
    {
      "source": "/(.*)\\.(html|css|js|json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
