# Copy to .env and fill in. NEVER commit .env.
SMTP_USER=your-burner@gmail.com     # burner Gmail that sends the alert
SMTP_PASS=abcdefghijklmnop          # Gmail 16-char App Password (no spaces)
ALERT_TO=your-burner@gmail.com      # where alerts go (can be your main inbox)
PUMP_ONLY=true                      # true = only pump.fun mints; false = all Solana
REQUIRE_WEBSITE=true                # true = only tokens that set a website
KEYWORDS=                           # optional: cat,ai,dog  (empty = everything)
MAX_ALERTS=20
POLL=25                             # seconds between checks
