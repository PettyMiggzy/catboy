# Copy to .env and fill in ONE notification channel (or more). NEVER commit .env.

# ── EASIEST: ntfy.sh (no account, no password) ─────────────────────────────
# 1) install the "ntfy" app on your phone (iOS/Android) or open ntfy.sh in a browser
# 2) subscribe to a SECRET topic name (make it unguessable) — e.g. below
# 3) put the same topic here. That's it — you get phone pushes.
NTFY_TOPIC=catboy-launch-CHANGE-ME-9f3k2

# ── OR: Telegram (easy) — message @BotFather to make a bot, get the token; ──
#     get your chat id from @userinfobot. Leave blank if not using.
TELEGRAM_TOKEN=
TELEGRAM_CHAT=

# ── OR: Email via Gmail (needs a 16-char App Password + 2FA). Leave blank if unused.
SMTP_USER=
SMTP_PASS=
ALERT_TO=

# ── filters ────────────────────────────────────────────────────────────────
PUMP_ONLY=true          # true = only pump.fun mints; false = all Solana
REQUIRE_WEBSITE=true    # true = only tokens that set a website
KEYWORDS=               # optional: cat,ai,dog  (empty = everything)
MAX_ALERTS=20
POLL=25                 # seconds between checks
