# STAG bot — copy to bot-server/.env and fill in. NEVER commit the real .env.
# Only the first block is required; the rest have sensible defaults.

# --- required ---
STAG_BOT_TOKEN=123456:your-telegram-bot-token
STAG_BOT_SECRET=any-long-random-string          # handler requires this to be non-empty
DATABASE_URL=postgres://user:pass@host/db        # same Neon DB the Vercel bot uses
STAG_VENICE_KEY=your-venice-INFERENCE-key         # for /pfp /image /vid (use an inference key, not admin)

# --- payments / verify (needed for /buy and /verify) ---
STAG_TREASURY=0xYourTreasuryWallet
STAG_VERIFY_WALLET=0xYourTreasuryWallet

# --- identity / owner ---
STAG_OWNER=6820752140                              # your Telegram user id (unlimited, free)
STAG_OWNER_NAME=King Petty
STAG_BOT_USERNAME=STAGZBOT

# --- announce chat (only used if RUN_CRONS=1) ---
STAG_ANNOUNCE_CHAT=-1003369963744

# --- run the on-chain announcer + video poller here too? ---
# 0 = leave them on Vercel (recommended while migrating). 1 = run them on this server.
RUN_CRONS=0

# --- chain (defaults are correct for Robinhood Chain mainnet; override only if needed) ---
# RHC_RPC=https://rpc.mainnet.chain.robinhood.com
# STAG_TOKEN=0xCDdB2d9838b7eDab2F04aF4943a6EFE42C2f9F49
# STAG_NFT=0x4384cB362D908d36266bDF3C31F18DB95EB127dc
# STAG_STAKING=0x2faA6672546912e7cDec4E1AaCF1eeF52bA524fF
